# Supabase Configuration (Required)
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Generative AI Configuration (Required)
# Get your API key from https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# NOTE: This is the FREE TIER version
# - OpenAI has been removed (no paid API calls)
# - Stripe has been disabled (no payment processing)
# - All AI features use Google Gemini free tier
# - All data is stored in Supabase free tier
# - No credit card required

# Production Deployment
# For production, set NEXT_PUBLIC_APP_URL to your domain
# Example: NEXT_PUBLIC_APP_URL=https://yourdomain.com
